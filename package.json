{
  "name": "plotop",
  "version": "0.0.0",
  "description": "Real-time performance plotting application",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "build": "tsc && rm -rf dist/renderer && cp -r src/renderer dist/renderer",
    "start": "electron dist/main.js",
    "web": "electron dist/main.js --web",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.caibingcheng.plotop",
    "productName": "Plotop",
    "executableName": "plotop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "icon": "assets/icon.png",
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development",
      "desktop": {
        "StartupWMClass": "Plotop"
      }
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
